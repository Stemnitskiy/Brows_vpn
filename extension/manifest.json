{
  "manifest_version": 3,
  "name": "Brows VPN",
  "version": "2.0.0",
  "description": "VPN для браузера через VLESS: выборочная или полная прокси-маршрутизация",
  "permissions": [
    "proxy",
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "nativeMessaging",
    "webRequest",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}